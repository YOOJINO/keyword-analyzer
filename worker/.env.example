# 이 파일을 복사해서 ".env" 파일을 만들고 값을 채워주세요.
# .env 는 git 에 올라가지 않습니다 (.gitignore 처리됨).

# 저장소 읽기/쓰기 권한이 있는 GitHub 토큰
# (Vercel 환경변수 GITHUB_TOKEN 과 같은 값을 써도 됩니다)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "소유자아이디/저장소이름" 형식
GITHUB_REPO=your-id/viral-marketing-lab

# GitHub 확인 주기(초). 기본 30
POLL_SECONDS=30
